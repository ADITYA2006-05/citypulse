datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

model IssueReport {
  id            String    @id @default(uuid())
  title         String
  description   String
  category      String    // POTHOLE, STREET_LIGHT, WASTE, TRAFFIC_SIGNAL, WATER_LEAK, DAMAGE, OTHER
  severity      String    // LOW, MEDIUM, HIGH
  status        String    // PENDING, IN_PROGRESS, RESOLVED
  address       String
  latitude      Float?
  longitude     Float?
  imageUrl      String?   // Base64 or mock URL of problem photo
  reporterName  String?
  reporterEmail String?
  upvotes       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      Comment[]
}

model Comment {
  id        String      @id @default(uuid())
  issueId   String
  issue     IssueReport @relation(fields: [issueId], references: [id], onDelete: Cascade)
  content   String
  isAdmin   Boolean     @default(false)
  createdAt DateTime    @default(now())
}
